#!/bin/sh -eu

# Rebuild the kernel and rootfs against the existing host toolchain. Used for
# iterative dev builds inside the running container after setup_buildroot.sh
# has done the initial provisioning.

BUILDROOT_VERSION=${BUILDROOT_VERSION:-2026.02.1}
BUILDROOT_DIR=/atomtools/build/buildroot-${BUILDROOT_VERSION}

if [ ! -d "${BUILDROOT_DIR}" ]; then
	cat >&2 <<EOF
ERROR: ${BUILDROOT_DIR} が見つかりません。

このブランチの build_all は Buildroot ${BUILDROOT_VERSION} を前提にしています。
docker-compose.yml の image が Docker Hub の古い atomtools/atomtools:Ver.* のままだと、
コンテナ内は Buildroot 2016.02 のみで、このパスは存在しません。

対処: このリポジトリの Dockerfile からイメージを作り直し、そのタグを compose に合わせてください
(例: make docker-build のあと、pull ではなくローカルイメージを使う)。
EOF
	exit 1
fi

cd "${BUILDROOT_DIR}/output"
rm -rf target
mkdir -p target/lib
cp -dpf staging/lib/libgcc_s.so* staging/lib/libatomic.so* target/lib/
mkdir -p target/usr/lib
cp -dpf staging/usr/lib/libstdc++.so* target/usr/lib/
find ./build -name ".stamp_target_installed*" -print | xargs rm -f
cd "${BUILDROOT_DIR}"
export BR2_EXTERNAL=/src/custompackages
cp /src/configs/atomcam_defconfig .config
cat /src/configs/atomcam_toolchain_external.fragment >> .config
make olddefconfig
for i in `ls /src/custompackages/package`
do
  if ! diff -urb /src/custompackages/package/$i package/$i > /dev/null 2>&1 ; then
    rm -rf package/$i
    cp -pr /src/custompackages/package/$i package
    [ "$i" != "Config.in" ] && make $i-dirclean
  fi
done
make
