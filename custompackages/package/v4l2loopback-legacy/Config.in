config BR2_PACKAGE_V4L2LOOPBACK_LEGACY
	bool "v4l2loopback (legacy, kernel 3.10 compatible)"
	depends on BR2_LINUX_KERNEL
	help
	  Pinned-old fork of v4l2loopback (umlaeute/v4l2loopback git
	  commit a6d82287) that still compiles against the Linux 3.10
	  kernel shipped with the Wyze Cam V3 / ATOMCam GPL drop.

	  Buildroot 2026.02 ships v4l2loopback 0.15.3, which has
	  `#error This module is not supported on kernels before 4.0.0.`
	  hard-coded; we therefore keep this in-tree fork and apply the
	  custom OOM/load-reduction patch
	  (0001-v4l2loopback-oom.patch) from the original ATOMCam tree.

	  https://github.com/umlaeute/v4l2loopback

if BR2_PACKAGE_V4L2LOOPBACK_LEGACY

config BR2_PACKAGE_V4L2LOOPBACK_LEGACY_UTILS
	bool "utils"
	depends on BR2_USE_MMU # bash
	select BR2_PACKAGE_BUSYBOX_SHOW_OTHERS # bash
	select BR2_PACKAGE_BASH # runtime dependency
	select BR2_PACKAGE_SUDO # runtime dependency
	help
	  Install applications to interact with v4l2-loopback devices
	  ("virtual video devices").  Currently there is only a single
	  command line utility: v4l2loopback-ctl: tool to set
	  framerate, format and timeout image.

endif

comment "v4l2loopback-legacy needs a Linux kernel to be built"
	depends on !BR2_LINUX_KERNEL
