#!/bin/sh
#
# Tailscale daemon init script
#

DAEMON="tailscaled"
TAILSCALE_SCRIPT="/scripts/tailscale.sh"

umask 077

start() {
	# TAILSCALE_ENABLE=on 以外は bash(tailscale.sh)を起動せず即終了(約1.8s 短縮)
	if ! grep -q "^TAILSCALE_ENABLE *= *on" /tmp/hack.ini 2>/dev/null; then
		echo "tailscale: disabled (TAILSCALE_ENABLE!=on)"
		return 0
	fi
	printf 'Starting %s: ' "$DAEMON"
	if [ -x "$TAILSCALE_SCRIPT" ]; then
		"$TAILSCALE_SCRIPT" start
		echo "OK"
	else
		echo "FAIL - script not found"
		return 1
	fi
}

stop() {
	printf 'Stopping %s: ' "$DAEMON"
	if [ -x "$TAILSCALE_SCRIPT" ]; then
		"$TAILSCALE_SCRIPT" stop
		echo "OK"
	else
		echo "FAIL - script not found"
		return 1
	fi
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}"
		exit 1
esac

exit $?
